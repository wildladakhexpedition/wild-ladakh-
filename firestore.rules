rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: reviews
    // Fields:
    //   - userName: string (required)
    //   - userPhoto: string (optional)
    //   - rating: number (required, 1-5)
    //   - comment: string (required, max 500 chars)
    //   - createdAt: timestamp (required)
    //   - userId: string (required)
    //   - status: string (required, ['pending', 'approved', 'rejected'])
    //
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - email: string (required)
    //   - photoURL: string (optional)
    //   - role: string (required, ['user', 'admin'])
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "wildladakhexpedition@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidReview(data) {
      return data.userName is string && data.userName.size() > 0 && data.userName.size() < 100 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() > 0 && data.comment.size() <= 500 &&
             data.createdAt is timestamp &&
             data.userId == request.auth.uid &&
             data.status in ['pending', 'approved', 'rejected'];
    }

    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() > 0 &&
             data.email is string &&
             data.role in ['user', 'admin'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /reviews/{reviewId} {
      // Allow everyone to read approved reviews
      allow read: if resource.data.status == 'approved' || isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      
      // Allow authenticated users to create a review (default status pending)
      allow create: if isAuthenticated() && isValidReview(request.resource.data) && request.resource.data.status == 'pending';
      
      // Allow owners to update their own pending reviews or admins to update anything
      allow update: if isAdmin() || (isOwner(resource.data.userId) && resource.data.status == 'pending' && isValidReview(request.resource.data) && request.resource.data.status == 'pending');
      
      // Allow admins to delete
      allow delete: if isAdmin();
    }
  }
}
